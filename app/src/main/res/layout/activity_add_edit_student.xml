<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_light">

    <!-- App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Student"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_save_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="SAVE"
            android:textColor="@color/teal"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scrollable Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Full Name"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_full_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:hint="Enter student's full name"
                android:inputType="textPersonName"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

            <!-- Roll Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Roll Number"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_roll_number"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:hint="Enter roll number"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

            <!-- Date of Birth -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Date of Birth"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_dob"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:hint="DD/MM/YYYY"
                android:inputType="date"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

            <!-- Birthday Certificate URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Birthday Certificate URL"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_bday_url"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:hint="HTTPS://..."
                android:inputType="textUri"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

            <!-- Standard -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Standard"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_standard"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:paddingHorizontal="14dp" />

            <!-- Division -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Division"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_division"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:paddingHorizontal="14dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Password"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input_border"
                android:hint="Create student login password"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

            <!-- Divider + Additional Info -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="20dp"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Additional Info"
                android:textColor="@color/primary_blue"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Phone Number (Optional)"
                android:textColor="@color/gray_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_border"
                android:hint="Enter parent's phone number"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_caption"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Fixed Save Button at Bottom -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_student"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ADD STUDENT"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_add"
            app:iconTint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>