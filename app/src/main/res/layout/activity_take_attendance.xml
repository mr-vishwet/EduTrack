<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/teal"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Take Attendance"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Info Bar — Class · Subject · Date -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <TextView
            android:id="@+id/tv_class_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="8th A · Mathematics · 15 Mar 2026"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_edit_class"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/gray_body" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/info_bar" />

    <!-- Quick Action Buttons — Mark All Present / Same as Yesterday -->
    <LinearLayout
        android:id="@+id/quick_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/divider1">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mark_all_present"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Mark All Present"
            android:textAllCaps="false"
            android:textColor="@color/teal"
            android:textSize="13sp"
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_check_circle"
            app:iconSize="16dp"
            app:iconTint="@color/teal"
            app:strokeColor="@color/teal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_same_as_yesterday"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Same as Yesterday"
            android:textAllCaps="false"
            android:textColor="@color/primary_blue"
            android:textSize="13sp"
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_calendar_today"
            app:iconSize="16dp"
            app:iconTint="@color/primary_blue"
            app:strokeColor="@color/primary_blue" />
    </LinearLayout>

    <!-- Shimmer Loading -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_view_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/footer_summary"
        app:layout_constraintTop_toBottomOf="@id/quick_actions">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="8"
            android:useDefaultMargins="true">
            <!-- 24 placeholder circles -->
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
            <View android:layout_width="44dp" android:layout_height="44dp" android:background="#DDDDDD" android:layout_margin="6dp"/>
        </GridLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <!-- Attendance Grid — scrollable -->
    <ScrollView
        android:id="@+id/scroll_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/footer_summary"
        app:layout_constraintTop_toBottomOf="@id/quick_actions">

        <GridLayout
            android:id="@+id/grid_attendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="8"
            android:useDefaultMargins="true" />

    </ScrollView>

    <!-- Footer — summary + save button -->
    <LinearLayout
        android:id="@+id/footer_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Present / Absent count badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_green"
                android:backgroundTint="#F1F5F9"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Present: 38  |  Absent: 4"
                android:textColor="@color/gray_body"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_attendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE ATTENDANCE"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>