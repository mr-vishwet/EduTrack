<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- App Bar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Class-wise Report"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/footer_export"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Filter Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Filter header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_filter_list"
                            app:tint="@color/primary_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set Filters"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Class Spinner -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="SELECT CLASS"
                        android:textColor="@color/gray_caption"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <Spinner
                        android:id="@+id/spinner_class"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingHorizontal="12dp" />

                    <!-- Subject Spinner -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="SELECT SUBJECT"
                        android:textColor="@color/gray_caption"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <Spinner
                        android:id="@+id/spinner_subject"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingHorizontal="12dp" />

                    <!-- Date range row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="FROM DATE"
                                android:textColor="@color/gray_caption"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <EditText
                                android:id="@+id/et_from_date"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_input_border"
                                android:focusable="false"
                                android:hint="DD/MM/YYYY"
                                android:inputType="none"
                                android:paddingHorizontal="12dp"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="TO DATE"
                                android:textColor="@color/gray_caption"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <EditText
                                android:id="@+id/et_to_date"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_input_border"
                                android:focusable="false"
                                android:hint="DD/MM/YYYY"
                                android:inputType="none"
                                android:paddingHorizontal="12dp"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Apply button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_apply"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="▶  Apply Filters &amp; Preview"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary_blue"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preview Table Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Report Preview"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_saved"
                            android:backgroundTint="#F1F5F9"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="First 5 rows"
                            android:textColor="@color/gray_caption"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9" />

                    <!-- Table header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/row_tint_blue"
                        android:paddingVertical="12dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="Class" android:textColor="@color/primary_blue"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Present"
                            android:textColor="@color/primary_blue"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Absent"
                            android:textColor="@color/primary_blue"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="%" android:textColor="@color/primary_blue"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Row 1: 8th A -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/white">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="8th A" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="38" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="4" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="90.5%" android:textColor="@color/present_green"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

                    <!-- Row 2: 8th B -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/white">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="8th B" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="35" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="7" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="83.3%" android:textColor="@color/present_green"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

                    <!-- Row 3: 9th A (red) -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/white">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="9th A" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="30" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="12" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="71.4%" android:textColor="@color/absent_red"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

                    <!-- Row 4: 9th B -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/white">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="9th B" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="41" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="1" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="97.6%" android:textColor="@color/present_green"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

                    <!-- Row 5: 10th A (red) -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/white">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="10th A" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="28" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="14" android:textColor="@color/gray_body" android:textSize="13sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="66.7%" android:textColor="@color/absent_red"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

                    <!-- Overall footer row -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingVertical="12dp" android:background="@color/green_badge_bg">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:paddingStart="16dp"
                            android:text="Overall" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="150" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="9" android:textColor="@color/black"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:paddingEnd="8dp"
                            android:text="94.3%" android:textColor="@color/present_green"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Fixed Export Footer -->
    <LinearLayout
        android:id="@+id/footer_export"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Branding checkbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_branding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Include school header &amp; branding in PDF"
                android:textColor="@color/gray_body"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Export buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_csv"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Export CSV"
                android:textAllCaps="false"
                android:textColor="@color/teal"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="@color/teal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_pdf"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Export PDF"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
